generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Barbershop {
  id        String   @id @default(uuid())
  name      String
  address   String
  description String
  imageUrl String
  phones     String[]
  services  BarbershopService[]
  createdAt DateTime @default(now())
}

model BarbershopService {
  id          String   @id @default(uuid())
  barbershopId String
  name        String
  description String
  imageUrl String
  priceInCents       Int

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])
}

model Booking {
  id          String   @id @default(uuid())
  barbershopId String
  serviceId    String
  date DateTime @db.Timestamptz
  cancelled   Boolean? @default(false)
  cancelledAt DateTime? @db.Timestamptz
}

//o preco - nao salvar valores monetarios como decimal no banco, o recomendado e salvar como centavos e inteiro no banco de dados e na aplicacao dividir por 100

//datas - o timestamptz salva ja com o fuso horario que eh o UTC, sempre salva datas com timestamptz